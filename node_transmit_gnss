#include <Arduino.h>
#include <SPI.h>
#include <RadioLib.h>
#include <TinyGPSPlus.h>

const char* NODE_ID = "Nx"; //assign node id 

//  GNSS 
static const int GNSS_RX_PIN = 4;   // ESP32 RX  <- L76X TX
static const int GNSS_TX_PIN = 5;   // ESP32 TX  -> L76X RX
static const int GNSS_PPS_PIN = 6;  

HardwareSerial GNSS(1);
TinyGPSPlus gps;

//  LoRa Lambda62-1 
static const int LORA_BUSY = 14;
static const int LORA_SCK  = 12;
static const int LORA_MISO = 13;    // module SDO
static const int LORA_MOSI = 11;    // module SDI
static const int LORA_NSS  = 10;
static const int LORA_RST  = 15;
static const int LORA_DIO1 = 9;
static const int LORA_RXEN = 16;
static const int LORA_TXEN = 17;

SPIClass LoRaSPI(FSPI);
SPISettings LoRaSPISettings(2000000, MSBFIRST, SPI_MODE0);

SX1262 radio = new Module(
  LORA_NSS,
  LORA_DIO1,
  LORA_RST,
  LORA_BUSY,
  LoRaSPI,
  LoRaSPISettings
);

unsigned long lastTx = 0;
const unsigned long TX_INTERVAL_MS = 2000;

static void feedGps() {
  while (GNSS.available()) {
    gps.encode(GNSS.read());
  }
}

[[noreturn]] static void haltWithError(int16_t code) {
  Serial.print("FATAL LoRa init failed, code = ");
  Serial.println(code);
  while (true) {
    delay(1000);
  }
}

void setup() {
  
  Serial.begin(115200);
  delay(2000);

  delay(1400);

  unsigned long t0 = millis();
  while (!Serial && millis() - t0 < 5000) {
    delay(10);
  }

  Serial.println();
  Serial.println("TX node booting");

  pinMode(GNSS_PPS_PIN, INPUT);

  GNSS.begin(9600, SERIAL_8N1, GNSS_RX_PIN, GNSS_TX_PIN);
  Serial.println("GNSS UART started");

  LoRaSPI.begin(LORA_SCK, LORA_MISO, LORA_MOSI, LORA_NSS);
  radio.setRfSwitchPins(LORA_RXEN, LORA_TXEN);

  // Match Pi receiver later:
  // 868.1 MHz, BW125, SF7, CR 4/5, sync word 0x34, 14 dBm, preamble 8
  int16_t state = radio.begin(868.1, 125.0, 7, 5, 0x34, 14, 8, 0.0);
  if (state != RADIOLIB_ERR_NONE) {
    haltWithError(state);
  }

  Serial.println("LoRa ready");
}

void loop() {
  feedGps();

  if (millis() - lastTx < TX_INTERVAL_MS) {
    return;
  }

String payload;
bool validFix = gps.location.isValid() && gps.location.age() < 5000;

if (validFix) {
  payload = "ID=" + String(NODE_ID) +
            ",LAT=" + String(gps.location.lat(), 6) +
            ",LON=" + String(gps.location.lng(), 6);

  if (gps.altitude.isValid()) {
    payload += ",ALT=" + String(gps.altitude.meters(), 1);
  }

  if (gps.satellites.isValid()) {
    payload += ",SAT=" + String(gps.satellites.value());
  } else {
    payload += ",SAT=0";
  }

  payload += ",FIX=1";
} else {
  payload = "ID=" + String(NODE_ID) + ",LAT=NOFIX,LON=NOFIX,FIX=0";

  if (gps.satellites.isValid()) {
    payload += ",SAT=" + String(gps.satellites.value());
  } else {
    payload += ",SAT=0";
  }
}

  int16_t state = radio.transmit(payload);

  if (state == RADIOLIB_ERR_NONE) {
    Serial.print("TX: ");
    Serial.println(payload);
  } else {
    Serial.print("TX failed, code = ");
    Serial.println(state);
  }

  lastTx = millis();
}
